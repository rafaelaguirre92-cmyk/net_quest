rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Students: users can only read/write their own doc
    match /students/{studentId} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
    }

    // Employers: any authenticated user can read
    match /employers/{employerId} {
      allow read: if true;
      allow write: if true; // Temporary for import

      // Job openings subcollection
      match /jobOpenings/{jobId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Empresas (New): any authenticated user can read
    match /empresas/{empId} {
      allow read: if true;
      allow write: if true; // Temporary for script sync

      match /jobOpenings/{jobId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Connections: users can create their own and read their own
    match /connections/{connectionId} {
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow read: if request.auth != null && resource.data.studentId == request.auth.uid;
      allow update, delete: if false;
    }

    // Manual contacts: users can create and list their own
    match /manualContacts/{docId} {
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow read, list: if request.auth != null;
      allow update, delete: if false;
    }

    // Activities: any authenticated user can read
    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
